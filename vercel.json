{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://uwm-engine.up.railway.app/api/$1"
    },
    {
      "source": "/ws",
      "destination": "https://uwm-engine.up.railway.app/ws"
    },
    {
      "source": "/(.*)",
      "destination": "/src/frontend/out/$1"
    }
  ]
}
